
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- GLOBAL HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- NEW: SHARED APP CONFIGURATION ---
    match /app_config/{docId} {
      // Allow any authenticated user to read/write the shared config
      allow read, write: if isSignedIn();
    }

    // --- COLLECTION RULES ---

    match /brokers/{brokerId} {
      // Permitimos que qualquer usuário autenticado gerencie a lista para este protótipo
      allow read, write: if isSignedIn();
    }

    match /properties/{propertyId} {
      allow read, write: if isSignedIn();
    }

    match /leads/{leadId} {
      allow read, write: if isSignedIn();
    }

    match /vendas_imoveis/{salesRecordId} {
      allow read, write: if isSignedIn();
    }

    match /visits/{visitId} {
      allow read, write: if isSignedIn();
    }

    match /roles_admin/{userId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}

    